# ============================================================
# AI-POWERED FEATURES (recommended, not required for first run)
# ============================================================
# Get your key at: https://platform.openai.com/api-keys
# Without this key, the app uses built-in scoring (still works!).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1-codex-mini

# ============================================================
# TELEGRAM DELIVERY (optional — set up later from web console)
# ============================================================
# Create a bot via @BotFather on Telegram to get your token.
# Chat/admin IDs are numeric — use @userinfobot to find yours.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_CHAT_IDS=
TELEGRAM_ADMIN_USER_IDS=

# ============================================================
# OBSIDIAN DELIVERY (optional)
# ============================================================
# Path to your Obsidian vault on disk (e.g. ~/Documents/MyVault).
OBSIDIAN_VAULT_PATH=
OBSIDIAN_FOLDER=AI Digest

# ============================================================
# GITHUB INGESTION (optional — improves API rate limits)
# ============================================================
# Create a token at: https://github.com/settings/tokens
GITHUB_TOKEN=

# ============================================================
# X / TWITTER INGESTION (optional)
# ============================================================
# Default mode (inbox_only) uses only manual links — no API needed.
# Set to x_api and provide a bearer token for automated ingestion.
DIGEST_X_PROVIDER=inbox_only
X_BEARER_TOKEN=
DIGEST_X_API_TIMEOUT=20
DIGEST_X_MAX_ITEMS_PER_SELECTOR=25

# ============================================================
# LOGGING (sensible defaults, rarely need changing)
# ============================================================
DIGEST_LOG_PATH=logs/digest.log
DIGEST_LOG_LEVEL=INFO
DIGEST_LOG_MAX_BYTES=5000000
DIGEST_LOG_BACKUP_COUNT=5

# ============================================================
# WEB CONSOLE AUTH (auto-generated on first start if empty)
# ============================================================
DIGEST_WEB_API_AUTH_MODE=required
DIGEST_WEB_API_TOKEN=
DIGEST_WEB_API_TOKEN_HEADER=X-Digest-Api-Token
